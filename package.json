{
  "name": "solar",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "start": "remotion studio src/index.ts",
    "preview": "remotion preview src/index.ts",
    "render": "npm run render:all",
    "render:all": "npm run render:en && npm run render:zh && npm run render:ja && npm run render:ko",
    "render:en": "remotion render src/index.ts SolarSystemEN out/solar-system-en.mp4",
    "render:zh": "remotion render src/index.ts SolarSystemZH out/solar-system-zh.mp4",
    "render:ja": "remotion render src/index.ts SolarSystemJA out/solar-system-ja.mp4",
    "render:ko": "remotion render src/index.ts SolarSystemKO out/solar-system-ko.mp4",
    "typecheck": "tsc --noEmit",
    "voiceover": "python scripts/generate_voiceover.py",
    "voiceover:edge": "python scripts/generate_voiceover.py --provider edge-tts",
    "voiceover:gcp": "python scripts/generate_voiceover.py --provider gcp"
  },
  "dependencies": {
    "@remotion/cli": "latest",
    "@remotion/renderer": "latest",
    "react": "latest",
    "react-dom": "latest",
    "remotion": "latest",
    "three": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/three": "latest",
    "typescript": "latest"
  }
}
